APP_NAME=newsvine-api
APP_ENV=local
APP_DATABASE_URL=postgresql+psycopg://newsvine:newsvine@localhost:5432/users
APP_ELASTICSEARCH_URL=http://localhost:9200
APP_REDIS_URL=redis://localhost:6379/0
APP_KAFKA_BOOTSTRAP_SERVERS=localhost:9092
APP_NEWS_TOPIC=news-articles
APP_USER_INTERACTIONS_TOPIC=user-interactions
APP_TRENDING_UPDATES_TOPIC=trending-updates
APP_NEWS_DLQ_TOPIC=news-articles-dlq
APP_JWT_SECRET=change-this-secret
APP_JWT_ALGORITHM=HS256
APP_ACCESS_TOKEN_MINUTES=15
APP_REFRESH_TOKEN_DAYS=7
APP_AUTO_CREATE_SCHEMA=false
APP_RECOMMENDATION_CONTENT_WEIGHT=0.6
APP_RECOMMENDATION_TRENDING_WEIGHT=0.3
APP_RECOMMENDATION_COLLABORATIVE_WEIGHT=0.1
APP_RECOMMENDATION_CANDIDATE_LIMIT=300
APP_RECOMMENDATION_FALLBACK_TTL_SECONDS=60
APP_RECOMMENDATION_TFIDF_BOOTSTRAP_DOCS=10000
APP_RECOMMENDATION_CATEGORY_EMBEDDING_CAP=500
APP_RECOMMENDATION_TOPIC_CANDIDATE_LIMIT=5
APP_TRENDING_FRESHNESS_DECAY_AFTER_DAYS=5.0
APP_TRENDING_FRESHNESS_MAX_AGE_DAYS=10.0
APP_REQUEST_RATE_LIMIT_PER_USER_PER_MINUTE=100
APP_REQUEST_RATE_LIMIT_PER_IP_PER_MINUTE=1000
APP_CORS_ALLOW_ORIGINS=*
APP_OTEL_ENABLED=false
APP_OTEL_SERVICE_NAME=newsvine-api
APP_OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318/v1/traces

# Phase 5 batch defaults (local-first)
PHASE5_SOURCE_BACKEND=local_postgres
PHASE5_EMBEDDINGS_DEST_BACKEND=local_postgres
PHASE5_MATRIX_TABLE=intermediate.int_user_article_matrix
PHASE5_ARTICLE_FEATURES_TABLE=marts.fct_article_features
PHASE5_EMBEDDINGS_TABLE=news_features.article_embeddings
PHASE5_ALS_RECOMMENDATIONS_TABLE=news_features.als_user_recommendations
PHASE5_MLFLOW_EXPERIMENT=phase5-als

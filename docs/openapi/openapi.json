        "type": "object",
        "title": "EventMetadata"
      },
      "EventRequest": {
        "properties": {
          "event_type": {
            "type": "string",
            "enum": [
              "click",
              "like",
              "bookmark",
              "search"
            ],
            "title": "Event Type"
          },
          "article_id": {
            "type": "string",
            "maxLength": 128,
            "minLength": 1,
            "title": "Article Id"
          },
          "query": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Query"
          },
          "metadata": {
            "$ref": "#/components/schemas/EventMetadata"
          }
        },
        "type": "object",
        "required": [
          "event_type",
          "article_id"
        ],
        "title": "EventRequest"
      },
      "HTTPValidationError": {
        "properties": {
          "detail": {
            "items": {
              "$ref": "#/components/schemas/ValidationError"
            },
            "type": "array",
            "title": "Detail"
          }
        },
        "type": "object",
        "title": "HTTPValidationError"
      },

            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Content Snippet"
          },
          "category": {
            "type": "string",
            "title": "Category"
          },
          "timestamp": {
            "type": "string",
            "title": "Timestamp"
          },
          "source": {
            "type": "string",
            "title": "Source"
